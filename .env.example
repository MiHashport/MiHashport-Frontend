# Base URL of the MiHashport backend API (see MiHashport-Backend repo)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Stellar network to target: "testnet" or "mainnet"
NEXT_PUBLIC_STELLAR_NETWORK=testnet

# Deployed contract ID for the MiHashport Soroban contract (see MiHashport-Contract repo)
NEXT_PUBLIC_CONTRACT_ID=
